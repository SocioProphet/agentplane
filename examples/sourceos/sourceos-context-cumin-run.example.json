  "runner": {
    "runnerType": "cumin",
    "executionMode": "dry_run",
    "forbidLocalMac": true,
    "runnerRef": "cumin://sourceos-context/default"
  },
  "toolProviderRef": "agentplane://tool-provider/smart-tree-context-provider",
