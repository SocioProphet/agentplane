{
  "apiVersion": "agentplane.socioprophet.org/v0.1",
  "kind": "AgenticOpsPersonaPolicy",
  "metadata": {
    "name": "research-throughput",
    "personaId": "research-throughput",
    "createdAt": "2026-05-13T12:00:00Z",
    "ownerRef": "SocioProphet/agentplane-maintainers",
    "labels": ["agentic-ops", "research", "budget-control"]
  },
  "spec": {
    "objectives": {
      "latency": 0.05,
      "throughput": 0.40,
      "costPredictability": 0.05,
      "correctness": 0.15,
      "auditability": 0.05,
      "opsSimplicity": 0.05,
      "reproducibility": 0.20,
      "collaboration": 0.05
    },
    "budgetDefaults": {
      "tokensInMax": 2000000,
      "tokensOutMax": 50000,
      "verificationTokensMax": 25000,
      "toolCallsMax": 500,
      "wallClockSecondsMax": 7200,
      "dollarsMax": 100.0,
      "degradationThresholds": {
        "warnRatio": 0.75,
        "degradeRatio": 0.90,
        "hardStopRatio": 1.0
      }
    },
    "agenticAxes": {
      "autonomyDepth": 100,
      "reversibility": "unrestricted",
      "planMode": "react",
      "maxReplans": 10,
      "verificationJudgeRate": 0.1,
      "selfConsistencyK": 1,
      "cascadeEnabled": true
    },
    "dataClassAllowlist": ["public", "internal"],
    "modelPolicy": {
      "routeMode": "cascade",
      "allowedModelTiers": ["small", "medium", "large", "local"],
      "cachePolicy": "prefix_cache_preferred"
    },
    "policyRefs": {
      "guardrailDecisionAbi": "guardrail-fabric://sourceos.guardrail.decision.v0.1",
      "policyFabricBudgetPolicy": "policy-fabric://agentic-ops/runtime-budget-control.v0.1",
      "diffHygieneGate": "SocioProphet/policy-fabric#44"
    },
    "telemetry": {
      "emitPerStepUco": true,
      "trajectoryHashChainRequired": true,
      "sinkRefs": [
        "agentplane://ledgerd/trajectory",
        "global-devsecops-intelligence://ops.agentic_runtime_budget"
      ]
    }
  }
