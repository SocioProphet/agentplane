{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sourceos.local/schemas/agentplane/receipt.schema.v0.1.json",
  "title": "AgentplaneReceipt",
  "type": "object",
  "required": [
    "receiptId",
    "runId",
    "stepId",
    "phase",
    "ts",
    "status",
    "payloadHash"
  ],
  "properties": {
    "receiptId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "stepId": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": [
        "validate",
        "place",
        "dispatch",
        "result",
        "replay",
        "compensate"
      ]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "payloadHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "outputHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "ledgerEventRef": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
