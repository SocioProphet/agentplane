{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/agentplane/receipts/integrity-evidence-request.v0.1.json",
  "title": "IntegrityEvidenceRequest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "recordType",
    "request_id",
    "run_id",
    "attempt_id",
    "boundary_ref",
    "admission_ref",
    "authority_state_ref",
    "authority_status",
    "safe_root",
    "path_set",
    "requested_by_ref",
    "requested_at",
    "receipt_hash"
  ],
  "properties": {
    "schemaVersion": {"const": "agentplane.integrity-evidence-request.v0.1"},
    "recordType": {"const": "IntegrityEvidenceRequest"},
    "request_id": {"type": "string"},
    "run_id": {"type": "string"},
    "attempt_id": {"type": "string"},
    "boundary_ref": {"type": "string"},
    "admission_ref": {"type": "string"},
    "authority_state_ref": {"type": "string"},
    "authority_status": {"type": "string", "enum": ["active", "reduced", "suspended", "revoked"]},
    "safe_root": {"type": "string"},
    "path_set": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "before_digest", "expected_digest"],
        "properties": {
          "path": {"type": "string"},
          "before_digest": {"type": "string", "pattern": "^sha256:"},
          "expected_digest": {"type": "string", "pattern": "^sha256:"}
        }
      }
    },
    "requested_by_ref": {"type": "string"},
    "requested_at": {"type": "string"},
    "labels": {"type": "object", "additionalProperties": {"type": "string"}},
    "receipt_hash": {"type": "string", "pattern": "^sha256:"}
  }
}
