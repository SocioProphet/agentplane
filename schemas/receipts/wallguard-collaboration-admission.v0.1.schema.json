{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/agentplane/receipts/wallguard-collaboration-admission.v0.1.schema.json",
  "title": "WallGuard Collaboration Admission Receipt v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "recordType",
    "receipt_id",
    "collaboration_request_id",
    "source_agent_wall_context_ref",
    "target_agent_wall_context_ref",
    "source_wall_ref",
    "target_wall_ref",
    "collaboration_action",
    "admitted",
    "admission_decision",
    "reason_code",
    "wall_decision_ref",
    "wall_decision_outcome",
    "receipt_hash",
    "issued_at"
  ],
  "properties": {
    "schemaVersion": {"const": "agentplane.wallguard-collaboration-admission.v0.1"},
    "recordType": {"const": "WallGuardCollaborationAdmissionReceipt"},
    "receipt_id": {"type": "string", "minLength": 1},
    "collaboration_request_id": {"type": "string", "minLength": 1},
    "source_agent_wall_context_ref": {"type": "string", "minLength": 1},
    "target_agent_wall_context_ref": {"type": "string", "minLength": 1},
    "source_wall_ref": {"type": "string", "minLength": 1},
    "target_wall_ref": {"type": "string", "minLength": 1},
    "collaboration_action": {"enum": ["agent_message", "subagent_delegation", "tool_grant", "action_dispatch", "memory_access", "clean_room_handoff"]},
    "admitted": {"type": "boolean"},
    "admission_decision": {"enum": ["admit", "deny", "require-review", "fail-closed"]},
    "reason_code": {"enum": ["same_wall_allowed", "cross_wall_denied", "missing_wall_context", "contaminated_session_state", "clean_room_handoff_required", "policy_decision_missing", "wall_decision_mismatch"]},
    "wall_decision_ref": {"type": "string", "minLength": 1},
    "wall_decision_outcome": {"enum": ["allow", "deny", "redact", "quarantine", "escalate", "clean_room_release_requested", "clean_room_release_allowed", "clean_room_release_denied"]},
    "fail_closed_reason": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "receipt_hash": {"type": "string", "pattern": "^sha256:"},
    "issued_at": {"type": "string", "minLength": 1}
  }
}
