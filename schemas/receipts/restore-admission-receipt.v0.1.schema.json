{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/agentplane/receipts/restore-admission-receipt.v0.1.schema.json",
  "title": "RestoreAdmissionReceipt v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "recordType",
    "receipt_id",
    "restore_attempt_id",
    "run_id",
    "governed_run_contract_ref",
    "original_attempt_context_ref",
    "requested_restore_action",
    "halt_reason",
    "verifier_state",
    "budget_remaining",
    "budget_required",
    "side_effect_boundary",
    "recovery_policy_posture",
    "admitted",
    "admission_decision",
    "admitted_actions",
    "blocked_actions",
    "operator_next_options",
    "evidence_refs",
    "issued_at",
    "receipt_hash"
  ],
  "properties": {
    "schemaVersion": {"const": "agentplane.restore-admission-receipt.v0.1"},
    "recordType": {"const": "RestoreAdmissionReceipt"},
    "receipt_id": {"type": "string", "minLength": 1},
    "restore_attempt_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "governed_run_contract_ref": {"type": "string", "minLength": 1},
    "original_attempt_context_ref": {"type": "string", "minLength": 1},
    "requested_restore_action": {
      "type": "string",
      "enum": [
        "retry_same_payload",
        "retry_replanned_payload",
        "resume_from_checkpoint",
        "rollback_only",
        "rollback_then_retry",
        "operator_review_only"
      ]
    },
    "halt_reason": {
      "type": "string",
      "enum": [
        "budget_exhausted",
        "verifier_failed",
        "policy_denied",
        "runtime_error",
        "operator_halt",
        "timeout",
        "network_denied",
        "side_effect_uncertain",
        "unknown"
      ]
    },
    "verifier_state": {"type": "string", "enum": ["passed", "failed", "stale", "missing", "inconclusive"]},
    "budget_remaining": {
      "type": "object",
      "additionalProperties": false,
      "required": ["remaining_budget_usd", "remaining_iterations", "remaining_tokens", "estimate_provenance"],
      "properties": {
        "remaining_budget_usd": {"type": "number", "minimum": 0},
        "remaining_iterations": {"type": "integer", "minimum": 0},
        "remaining_tokens": {"type": "integer", "minimum": 0},
        "estimate_provenance": {"type": "string", "enum": ["actual", "estimated", "unavailable"]}
      }
    },
    "budget_required": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_budget_usd", "required_iterations", "required_tokens", "estimate_provenance"],
      "properties": {
        "required_budget_usd": {"type": "number", "minimum": 0},
        "required_iterations": {"type": "integer", "minimum": 0},
        "required_tokens": {"type": "integer", "minimum": 0},
        "estimate_provenance": {"type": "string", "enum": ["actual", "estimated", "unavailable"]}
      }
    },
    "side_effect_boundary": {"type": "string", "enum": ["none", "possible", "confirmed", "unknown"]},
    "recovery_policy_posture": {"type": "string", "enum": ["eligible_for_retry", "requires_review", "blocked"]},
    "admitted": {"type": "boolean"},
    "admission_decision": {"type": "string", "enum": ["admit", "require-review", "deny", "fail-closed"]},
    "admitted_actions": {
      "type": "array",
      "items": {"type": "string", "enum": ["retry_same_payload", "retry_replanned_payload", "resume_from_checkpoint", "rollback_only", "rollback_then_retry"]},
      "uniqueItems": true
    },
    "blocked_actions": {
      "type": "array",
      "items": {"type": "string", "enum": ["retry_same_payload", "retry_replanned_payload", "resume_from_checkpoint", "rollback_only", "rollback_then_retry"]},
      "uniqueItems": true
    },
    "operator_next_options": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "enum": ["retry", "review_original_attempt", "inspect_dossier", "rollback", "settle_budget", "refresh_verifier", "stop"]},
      "uniqueItems": true
    },
    "review_reason": {"type": ["string", "null"]},
    "fail_closed_reason": {"type": ["string", "null"]},
    "evidence_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "original_attempt_context_ref": {"type": "string", "minLength": 1},
        "attempt_admission_receipt_ref": {"type": "string", "minLength": 1},
        "budget_settlement_receipt_ref": {"type": "string", "minLength": 1},
        "verifier_receipt_ref": {"type": "string", "minLength": 1},
        "runtime_receipt_ref": {"type": "string", "minLength": 1},
        "run_dossier_ref": {"type": "string", "minLength": 1},
        "rollback_boundary_ref": {"type": "string", "minLength": 1},
        "operator_assertion_ref": {"type": "string", "minLength": 1}
      }
    },
    "issued_at": {"type": "string", "minLength": 1},
    "receipt_hash": {"type": "string", "pattern": "^sha256:"},
    "labels": {"type": "object", "additionalProperties": {"type": "string"}}
  }
}
