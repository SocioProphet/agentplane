{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReasoningFailureTrace",
  "description": "Typed execution evidence for reasoning failures and multi-agent coordination failures in AgentPlane runs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "trace_id",
    "task_id",
    "actor_id",
    "typed_intent",
    "failure_cluster",
    "failure_annotation",
    "termination_authority",
    "verifier_required",
    "residual_risk",
    "recorded_at"
  ],
  "properties": {
    "apiVersion": { "const": "agentplane.socioprophet.org/v0.1" },
    "kind": { "const": "ReasoningFailureTrace" },
    "trace_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "typed_intent": { "type": "string", "minLength": 1 },
    "failure_cluster": {
      "type": "string",
      "enum": [
        "specification_system_design",
        "inter_agent_misalignment",
        "task_verification_termination"
      ]
    },
    "failure_annotation": { "type": "string", "minLength": 1 },
    "claim_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "invariant_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "assumptions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "uncertainty_notes": { "type": "string" },
    "allowed_tools": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "capability_envelope_ref": { "type": "string", "minLength": 1 },
    "verifier_required": { "type": "boolean" },
    "verifier_decision": {
      "type": "string",
      "enum": ["passed", "failed", "inconclusive", "not_run", "deferred"]
    },
    "termination_authority": { "type": "string", "minLength": 1 },
    "escalation_rule": { "type": "string", "minLength": 1 },
    "residual_risk": {
      "type": "string",
      "enum": ["none", "low", "medium", "high", "critical"]
    },
    "llm_rationale_unsupported": { "type": "boolean" },
    "reasoning_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "description", "outcome"],
        "properties": {
          "step_id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "outcome": { "type": "string", "enum": ["ok", "failed", "inconclusive"] },
          "evidence_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "inter_agent_alignment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agents": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "independent_evidence_required": { "type": "boolean" },
        "agreement_without_evidence": { "type": "boolean" }
      }
    },
    "recorded_at": { "type": "string", "format": "date-time" }
  }
}
