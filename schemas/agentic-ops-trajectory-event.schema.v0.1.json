{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/agentplane/agentic-ops-trajectory-event.schema.v0.1.json",
  "title": "Agentic Ops Trajectory Event",
  "description": "Per-step UCO and hash-chain event contract for AgentPlane agentic runs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {"const": "agentplane.socioprophet.org/v0.1"},
    "kind": {"const": "AgenticOpsTrajectoryEvent"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventId", "runId", "sequence", "capturedAt"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "personaId": {"type": "string", "minLength": 1},
        "taskRef": {"type": "string", "minLength": 1},
        "repository": {"type": "string", "minLength": 1},
        "runId": {"type": "string", "minLength": 1},
        "eventId": {"type": "string", "minLength": 1},
        "sequence": {"type": "integer", "minimum": 0},
        "createdAt": {"type": "string", "format": "date-time"},
        "capturedAt": {"type": "string", "format": "date-time"},
        "ownerRef": {"type": "string", "minLength": 1},
        "labels": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "personaPolicyRef": {"type": "string", "minLength": 1},
        "workloadSignatureRef": {"type": "string", "minLength": 1}
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stepKind", "actorRef", "uco", "cache", "hashes", "decisions"],
      "properties": {
        "stepKind": {"enum": ["model_call", "tool_call", "verification", "memory_write", "degradation", "termination"]},
        "actorRef": {"type": "string"},
        "modelTier": {"type": "string"},
        "toolName": {"type": "string"},
        "uco": {"$ref": "#/$defs/ucoVector"},
        "cache": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cacheablePrefixTokens", "cacheHitTokens", "cacheHitRatio"],
          "properties": {
            "cacheablePrefixTokens": {"type": "integer", "minimum": 0},
            "cacheHitTokens": {"type": "integer", "minimum": 0},
            "cacheHitRatio": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "hashes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["previousEventHash", "eventHash"],
          "properties": {
            "previousEventHash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "eventHash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "promptDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "outputDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "toolArgsDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
          }
        },
        "decisions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["admissionDecision"],
          "properties": {
            "admissionDecision": {"enum": ["admit", "reject", "admit_with_degradation"]},
            "guardrailDecisionRef": {"type": "string"},
            "policyDecisionRefs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
          }
        }
      }
    }
  },
  "$defs": {
    "ucoVector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tokensIn", "tokensOut", "cachedTokens", "verificationTokens", "toolCalls", "wallClockSeconds", "dollars"],
      "properties": {
        "tokensIn": {"type": "integer", "minimum": 0},
        "tokensOut": {"type": "integer", "minimum": 0},
        "cachedTokens": {"type": "integer", "minimum": 0},
        "verificationTokens": {"type": "integer", "minimum": 0},
        "toolCalls": {"type": "integer", "minimum": 0},
        "wallClockSeconds": {"type": "number", "minimum": 0},
        "dollars": {"type": "number", "minimum": 0}
      }
    }
  }
}
