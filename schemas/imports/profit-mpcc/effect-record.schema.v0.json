{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/effect-record.schema.json",
  "title": "EffectRecord",
  "type": "object",
  "required": [
    "effect_record_id",
    "effect_id",
    "execution_status"
  ],
  "properties": {
    "effect_record_id": { "type": "string" },
    "effect_id": { "type": "string" },
    "execution_status": {
      "type": "string",
      "enum": ["authorized", "executed", "failed", "skipped", "compensated"]
    },
    "executor_id": { "type": "string" },
    "execution_context": {
      "type": "object",
      "additionalProperties": true
    },
    "actual_effect": {
      "type": "object",
      "additionalProperties": true
    },
    "approved_by": { "type": "string" },
    "idempotence_key": { "type": "string" },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "compensation_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "policy_labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risk_labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "provenance_links": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
