{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/agentplane/agentic-ops-budget-ledger.schema.v0.1.json",
  "title": "Agentic Ops Budget Ledger",
  "description": "Budget ledger contract for admitted AgentPlane agentic runs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {"const": "agentplane.socioprophet.org/v0.1"},
    "kind": {"const": "AgenticOpsBudgetLedger"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runId", "personaPolicyRef", "workloadSignatureRef", "createdAt"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "personaId": {"type": "string", "minLength": 1},
        "taskRef": {"type": "string", "minLength": 1},
        "repository": {"type": "string", "minLength": 1},
        "runId": {"type": "string", "minLength": 1},
        "eventId": {"type": "string", "minLength": 1},
        "sequence": {"type": "integer", "minimum": 0},
        "createdAt": {"type": "string", "format": "date-time"},
        "capturedAt": {"type": "string", "format": "date-time"},
        "ownerRef": {"type": "string", "minLength": 1},
        "labels": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "personaPolicyRef": {"type": "string", "minLength": 1},
        "workloadSignatureRef": {"type": "string", "minLength": 1}
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["admissionDecision", "caps", "observed", "remaining", "degradationState", "degradationActions", "policyRefs"],
      "properties": {
        "admissionDecision": {"enum": ["admit", "reject", "admit_with_degradation"]},
        "rejectionReason": {"type": "string"},
        "caps": {"$ref": "#/$defs/ucoVector"},
        "observed": {"$ref": "#/$defs/ucoVector"},
        "remaining": {"$ref": "#/$defs/ucoVector"},
        "degradationState": {"enum": ["normal", "warn", "degraded", "hard_stop", "terminated"]},
        "degradationActions": {
          "type": "array",
          "items": {"enum": ["switch_to_cheaper_model", "disable_model_cascade", "reduce_verification_sampling", "force_plan_then_execute", "cap_remaining_replans", "terminate_with_partial_result", "require_human_checkpoint"]},
          "uniqueItems": true
        },
        "policyRefs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    }
  },
  "$defs": {
    "ucoVector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tokensIn", "tokensOut", "cachedTokens", "verificationTokens", "toolCalls", "wallClockSeconds", "dollars"],
      "properties": {
        "tokensIn": {"type": "integer", "minimum": 0},
        "tokensOut": {"type": "integer", "minimum": 0},
        "cachedTokens": {"type": "integer", "minimum": 0},
        "verificationTokens": {"type": "integer", "minimum": 0},
        "toolCalls": {"type": "integer", "minimum": 0},
        "wallClockSeconds": {"type": "number", "minimum": 0},
        "dollars": {"type": "number", "minimum": 0}
      }
    }
  }
}
