{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.dev/agentplane/sandbox/runtime-certification-state.v0.1.schema.json",
  "title": "RuntimeCertificationState v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "state_ref",
    "runtime_run_ref",
    "current_state",
    "promotion_chain",
    "evidence_refs",
    "blocking_gaps",
    "authority",
    "effects",
    "non_claims"
  ],
  "properties": {
    "schema_version": { "const": "0.1" },
    "state_ref": { "type": "string", "pattern": "^agentplane:runtime-certification-state:" },
    "runtime_run_ref": { "type": "string", "pattern": "^agentplane:runtime-sandbox-run:" },
    "current_state": {
      "type": "string",
      "enum": [
        "contract_only",
        "runtime_observed",
        "teardown_verified",
        "leak_check_verified",
        "runtime_certified"
      ]
    },
    "promotion_chain": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["state", "entered_at", "evidence_ref", "promotion_allowed"],
        "properties": {
          "state": {
            "type": "string",
            "enum": [
              "contract_only",
              "runtime_observed",
              "teardown_verified",
              "leak_check_verified",
              "runtime_certified"
            ]
          },
          "entered_at": { "type": "string" },
          "evidence_ref": { "type": ["string", "null"] },
          "promotion_allowed": { "type": "boolean" },
          "blocked_by": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "evidence_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_ref",
        "runtime_observation_ref",
        "teardown_ref",
        "leak_check_ref",
        "certification_receipt_ref"
      ],
      "properties": {
        "contract_ref": { "type": ["string", "null"] },
        "runtime_observation_ref": { "type": ["string", "null"] },
        "teardown_ref": { "type": ["string", "null"] },
        "leak_check_ref": { "type": ["string", "null"] },
        "certification_receipt_ref": { "type": ["string", "null"] }
      }
    },
    "blocking_gaps": { "type": "array", "items": { "type": "string" } },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state_authority", "execution_authority", "certification_authority"],
      "properties": {
        "state_authority": { "const": "AgentPlane" },
        "execution_authority": { "const": "AgentPlane" },
        "certification_authority": { "const": "AgentPlane" }
      }
    },
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_parity_certified",
        "autonomy_allowed",
        "promotion_allowed",
        "human_review_required"
      ],
      "properties": {
        "runtime_parity_certified": { "type": "boolean" },
        "autonomy_allowed": { "type": "boolean" },
        "promotion_allowed": { "type": "boolean" },
        "human_review_required": { "type": "boolean" }
      }
    },
    "non_claims": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  }
}
