{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.io/schemas/agentplane/sandbox-run/v0.1.0",
  "title": "SandboxRun",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sandboxRunId",
    "requestRef",
    "executorPlane",
    "executionMode",
    "runStatus",
    "baselineRef",
    "changedServiceRefs",
    "routingMode",
    "asyncIsolationMode",
    "statefulResourceMode",
    "evidenceRefs",
    "receiptRefs",
    "teardownState",
    "issuedAt",
    "nonClaims"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.1.0" },
    "sandboxRunId": { "type": "string", "pattern": "^agentplane:sandbox-run:" },
    "requestRef": { "type": "string", "pattern": "^environment:validate-change-v2-request:" },
    "executorPlane": { "type": "string", "const": "AgentPlane" },
    "executionMode": { "type": "string", "enum": ["synthetic_fixture"] },
    "runStatus": { "type": "string", "enum": ["sandbox_requested", "sandbox_observed", "sandbox_failed"] },
    "baselineRef": { "type": "string", "pattern": "^workspace://" },
    "changedServiceRefs": { "type": "array", "items": { "type": "string" } },
    "routingMode": { "type": "string", "enum": ["not_configured", "synthetic_no_network"] },
    "asyncIsolationMode": { "type": "string", "enum": ["not_configured", "synthetic_no_network"] },
    "statefulResourceMode": { "type": "string", "enum": ["not_configured", "synthetic_no_network"] },
    "evidenceRefs": { "type": "array", "items": { "type": "string", "pattern": "^evidence://" } },
    "receiptRefs": { "type": "array", "items": { "type": "string", "pattern": "^receipt://" } },
    "failureCodes": { "type": "array", "items": { "type": "string" }, "default": [] },
    "teardownState": { "type": "string", "enum": ["not_required_synthetic", "teardown_complete", "teardown_failed"] },
    "issuedAt": { "type": "string", "format": "date-time" },
    "nonClaims": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  }
}
